# ==========================================
# Dependencies & Modules
# ==========================================
# Ignores node_modules in root, frontend, and backend
**/node_modules/
**/jspm_packages/

# ==========================================
# Environment Variables & Secrets
# ==========================================
# Ignores all .env files in any subfolder
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
**/.env.*.local

# ==========================================
# Build & Output Folders
# ==========================================
# Standard for React, Vite, Next.js, and Express builds
**/dist/
**/build/
**/out/
**/.next/
**/.cache/

# ==========================================
# Logs & Debugging
# ==========================================
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*

# ==========================================
# Databases & Local Storage
# ==========================================
# Prevents committing local database instances
**/*.sqlite
**/*.db
**/.local_db/

# ==========================================
# Operating System Files
# ==========================================
.DS_Store
.DS_Store?
**/Thumbs.db
**/ehthumbs.db